{
  "root": true,
  "plugins": ["playwright"],
  "extends": [
    "eslint:recommended",
    "plugin:playwright/recommended"
  ],
  "env": {
    "node": true,
    "es2020": true
  },
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "playwright/expect-expect": "error",
    "playwright/no-skipped-test": "warn",
    "playwright/no-focused-test": "error"
  },
  "ignorePatterns": ["node_modules/", "playwright-report/", "allure-results/"]
}
